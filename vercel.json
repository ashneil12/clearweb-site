{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "links.clearweb.one" }],
      "destination": "https://clearweb.one/",
      "permanent": true
    },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "links.clearweb.one" }],
      "destination": "https://clearweb.one/:path*",
      "permanent": true
    }
  ]
}
